# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
texput.log

# Editor backups of paper sources
paper/*.pre_*.tex

# Rust build
rust_prototype/target/
Cargo.lock.bak

# Python
__pycache__/
*.pyc
.venv/
venv/

# Nuclear data (too large, download separately per README)
data/

# Agent / tool state
.claude/

# Compiled CUDA benchmarks
cuda_bench/svd_gpu_bench
cuda_bench/*.exe
cuda_bench/*.exp
cuda_bench/*.lib

# OS
.DS_Store
Thumbs.db

# Top-level benchmark-run dumps — use scripts/pwr_verdict.py and
# outputs/ for persistent artefacts; dated one-shot logs at the
# repo root are local-only by convention.
/benchmark_*.txt
/paper_results_*.txt
/results_*.txt
/resume.md

# maturin / PyO3 build artefacts dropped into the Python package tree
# by `maturin develop`. Only the source files (Cargo.toml,
# pyproject.toml, src/, python/open_rust_mc/__init__.py, examples/)
# should live in git.
rust_prototype/bindings/python/python/open_rust_mc/*.pyd
rust_prototype/bindings/python/python/open_rust_mc/*.so
rust_prototype/bindings/python/python/open_rust_mc/*.dylib
rust_prototype/bindings/python/python/open_rust_mc/*.pdb
rust_prototype/bindings/python/python/open_rust_mc/__pycache__/
